// include standard library for useful constants
.stdlib

// GBA header
.begin header
  .arm
  b main
  .logo
  .title "GAME"
  .str "CUNE77"
  .i16 150, 0, 0, 0, 0
  .i8 0            // version
  .crc
  .i16 0
  b header         // ensure ROM isn't interpreted as multi-boot
  .str "SRAM_Vnnn" // tell emulators to reserve 32K of SRAM
  .align 4
.end

.begin main
    .arm
    // number of assertions
    mov r8, #4
    // stack
    ldr sp, =0x03008000
    // test result, pushed onto stack
    mov r0, #1         

    ldr pc, =l1
    b fail
l1: // 20
    push {r0}

    add pc, pc, #0
    b fail
    push {r0} // 32

    mov r1, pc
    add r1, r1, #8
    mov pc, r1
    b fail
    push {r0}

    mov r1, pc
    add r1, r1, #12
    push {r1}
    pop {pc}
    b fail
    push {r0}
    b exit

fail:
    ldr r9, =-1
    push {r9}
exit: 
    // emulator test exit condition
    mov r11, #0x6300
    b end
end:
    b end
.pool
.end