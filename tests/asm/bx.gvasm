// include standard library for useful constants
.stdlib

// GBA header
.begin header
  .arm
  b main
  .logo
  .title "GAME"
  .str "CUNE77"
  .i16 150, 0, 0, 0, 0
  .i8 0            // version
  .crc
  .i16 0
  b header         // ensure ROM isn't interpreted as multi-boot
  .str "SRAM_Vnnn" // tell emulators to reserve 32K of SRAM
  .align 4
.end

.begin main
    .arm
    // number of assertions
    mov r8, #2
    // stack
    ldr sp, =0x03008000

    ldr r0, =thumb
    add r0, r0, #1
    bx r0
thumb:
    .thumb
    mov r1, #1
    push {r1}
    ldr r0, =exit
    bx r0
exit:
    .align 4
    .arm
    push {r1}
    mov r11, #0x6300
    b end
end:
    b end
.pool
.end