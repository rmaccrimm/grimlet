.begin main
    .arm
    // not really assertions but one push from ARM, one from THUMB
    mov r6, #2
    // stack
    ldr sp, =0x03008000

    ldr r0, =thumb
    add r0, r0, #1
    bx r0
thumb:
    .thumb
    mov r1, #1
    push {r1}
    ldr r0, =exit
    bx r0
exit:
    .align 4
    .arm
    push {r1}
    mov r11, #0x6300
    b end
end:
    b end
.pool
.end