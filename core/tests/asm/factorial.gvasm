.begin main
    .arm
    // number of test cases - incremented as we go
    mov r6, #0
    // stack
    ldr sp, =0x03008000
    b case_1
init:
    add r6, r6, #1
    mov pc, lr
fail:
    ldr r7, =-1
    push {r7}
    b exit
success:
    mov r7, #1
    push {r7}
    mov pc, lr

// subroutine: r1 <- factorial(r0)
factorial:
    cmp r0, #1
    ble base_case
    mov r1, r0
    mov r0, #1
loop:
    mul r0, r0, r1  
    subs r1, r1, #1
    bgt loop
    mov r1, r0
    mov pc, lr
base_case:
    mov r1, #1
    mov pc, lr

case_1:
    bl init
    mov r0, #0
    bl factorial
    mov r0, #1
    cmp r0, r1
    bne fail
    bl success

case_2:
    bl init
    mov r0, #1
    bl factorial
    mov r0, #1
    cmp r0, r1
    bne fail
    bl success

case_3:
    bl init
    mov r0, #2 
    bl factorial
    mov r0, #2
    cmp r0, r1
    bne fail
    bl success

case_4:
    bl init    
    mov r0, #3
    bl factorial
    mov r0, #6
    cmp r0, r1
    bne fail
    bl success

case_5:
    bl init
    mov r0, #4
    bl factorial
    mov r0, #24
    cmp r0, r1
    bne fail
    bl success

case_6:
    bl init
    mov r0, #5
    bl factorial
    mov r0, #120
    cmp r0, r1
    bne fail
    bl success

case_7:
    bl init
    mov r0, #12
    bl factorial
    ldr r0, =479001600
    cmp r0, r1
    bne fail
    bl success
exit: 
    // emulator test exit condition
    mov r11, #0x6300
    b end
end:
    b end
.pool
.end
