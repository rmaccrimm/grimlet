.begin main
    .arm
    // number of test cases - incremented as we go
    mov r6, #0
    // stack
    ldr sp, =0x03008000
    // data address
    ldr r10, =data

    b case_1
init:
    add r6, r6, #1
    mov pc, lr
fail:
    ldr r7, =-1
    push {r7}
    b exit
success:
    mov r7, #1
    push {r7}
    mov pc, lr

case_1: // 1. load word 1
    bl init
    ldr r0, [r10]
    ldr r1, =0x56c7c13d
    cmp r0, r1
    bne fail
    bl success

case_2:  // 2. load word 2
    bl init
    ldr r0, [r10, #4]
    ldr r1, =0x4800c3c4
    cmp r0, r1
    bne fail
    bl success

case_3: 
    bl init
    // 3. load halfword 1
    ldrh r0, [r10]
    ldr r1, =0xc13d
    cmp r0, r1
    bne fail
    bl success
    
case_4: 
    bl init    
// 4. load halfword, halfword-alligned
    ldrh r0, [r10, #2]
    ldr r1, =0x56c7
    cmp r0, r1
    bne fail
    bl success

case_5: 
    bl init
// 5. load byte 1
    ldrb r0, [r10]
    ldr r1, =0x3d
    cmp r0, r1
    bne fail
    bl success

case_6: 
    bl init
// 6. load byte 2
    ldrb r0, [r10, #1]
    ldr r1, =0xc1
    cmp r0, r1
    bne fail
    bl success

case_7: 
    bl init
// 7. load byte 3
    ldrb r0, [r10, #2]
    ldr r1, =0xc7
    cmp r0, r1
    bne fail
    bl success

case_8: 
    bl init
// 8. load word, rotated offset
    mov r2, #1
    ldr r0, [r10, r2, ror #30] // = 4
    ldr r1, =0x4800c3c4
    cmp r0, r1
    bne fail
    bl success

case_9: 
    bl init
// 9-10. load word, writeback pre-increment
    ldr r2, =empty
    ldr r0, [r2, #-8]!
    ldr r1, =0x56c7c13d
    cmp r0, r1
    bne fail
    bl success

case_10: 
    bl init
    cmp r2, r10
    bne fail
    bl success

case_11: 
    bl init
// 11-12. load word, writeback post-increment
    ldr r2, =empty
    ldr r0, [r2], #-8
    ldr r1, =0x00000000
    cmp r0, r1
    bne fail
    bl success

case_12: 
    bl init
    cmp r2, r10
    bne fail
    bl success

case_13: 
    bl init
// 13. store word 1
    ldr r10, =0x03000000
    ldr r2, =0xf170339c
    str r2, [r10]
    ldr r1, [r10]
    cmp r1, r2
    bne fail
    bl success

case_14: 
    bl init
// 14-15. store word 2, writeback pre-increment
    ldr r2, =0xe03bbd00
    mov r3, r10
    str r2, [r3, #4]!
    sub r3, r3, #4
    cmp r3, r10
    bne fail
    bl success

case_15: 
    bl init
    ldr r1, [r10, #4]
    cmp r1, r2
    bne fail
    bl success

case_16: 
    bl init
// 16-23. store byte and halfword, load multiple
    ldr r2, =0x0343a12c
    mov r3, r10    
    add r10, r10, #8
    str r2, [r10], #4
    add r3, r3, #12
    cmp r10, r3
    bne fail
    bl success

case_17: 
    bl init
    ldr r2, =0x5eb79b81 // upper bytes will be ignored
    strh r2, [r10], #4

    ldr r2, =0x03000000
    add r2, r2, #16
    cmp r10, r2 // checking r10 is still where expected
    bne fail
    bl success

case_18: 
    bl init
    ldr r2, =0x45851dc3 // upper bytes will be ignored
    strb r2, [r10, #4] // skipping a word, since r10 was already incremented

    ldr r10, =0x03000000
    // These are checked in cases 18 - 23
    ldmia r10, {r1, r2, r3, r4, r5, r8} 

    ldr r0, =0xf170339c
    cmp r1, r0
    bne fail
    bl success

case_19: 
    bl init
    ldr r0, =0xe03bbd00
    cmp r2, r0
    bne fail
    bl success

case_20: 
    bl init
    ldr r0, =0x0343a12c
    cmp r3, r0
    bne fail
    bl success

case_21: 
    bl init
    ldr r0, =0x00009b81
    cmp r4, r0
    bne fail
    bl success

case_22: 
    bl init
    mov r0, #0
    cmp r5, r0
    bne fail
    bl success

case_23: 
    bl init
    ldr r0, =0x000000c3
    cmp r8, r0
    bne fail
    bl success
    b case_24

// From emulator.rs originally, tested by just checking mem array after
stmdb_setup:
    // address to write to
    ldr r9, =0x4000
    mov r0, #1
    mov r1, #2
    mov r2, #3
    mov r3, #5
    mov r4, #7
    mov r5, #11
    mov r7, #13
    mov r8, #17
    mov pc, lr

case_24: // stmdb writeback
    bl init
    bl stmdb_setup
    stmdb r9!, {r0, r2, r5, r1, r3, r8, r7, r4}
    ldr r11, =0x4000
    sub r11, r11, #32
    // Check mem register was written to, check values stored in following cases
    cmp r9, r11
    bne fail
    bl success

case_25:
    bl init
    ldr r12, [r11], #4
    cmp r12, #1
    bne fail
    bl success

case_26:
    bl init
    ldr r12, [r11], #4
    cmp r12, #2
    bne fail
    bl success

case_27:
    bl init
    ldr r12, [r11], #4
    cmp r12, #3
    bne fail
    bl success

case_28:
    bl init
    ldr r12, [r11], #4
    cmp r12, #5
    bne fail
    bl success

case_29:
    bl init
    ldr r12, [r11], #4
    cmp r12, #7
    bne fail
    bl success

case_30:
    bl init
    ldr r12, [r11], #4
    cmp r12, #11
    bne fail
    bl success

case_31:
    bl init
    ldr r12, [r11], #4
    cmp r12, #13
    bne fail
    bl success

case_32:
    bl init
    ldr r12, [r11], #4
    cmp r12, #17
    bne fail
    bl success

case_33: // stmdb no writeback
    bl init
    bl stmdb_setup
    stmdb r9, {r0, r5, r2, r8, r7, r3, r1, r4}
    ldr r11, =0x4000
    // Check mem register was written to, check values stored in following cases
    cmp r9, r11
    bne fail
    bl success
    sub r11, r11, #32

case_34:
    bl init
    ldr r12, [r11], #4
    cmp r12, #1
    bne fail
    bl success

case_35:
    bl init
    ldr r12, [r11], #4
    cmp r12, #2
    bne fail
    bl success

case_36:
    bl init
    ldr r12, [r11], #4
    cmp r12, #3
    bne fail
    bl success

case_37:
    bl init
    ldr r12, [r11], #4
    cmp r12, #5
    bne fail
    bl success

case_38:
    bl init
    ldr r12, [r11], #4
    cmp r12, #7
    bne fail
    bl success

case_39:
    bl init
    ldr r12, [r11], #4
    cmp r12, #11
    bne fail
    bl success

case_40:
    bl init
    ldr r12, [r11], #4
    cmp r12, #13
    bne fail
    bl success

case_41:
    bl init
    ldr r12, [r11], #4
    cmp r12, #17
    bne fail
    bl success

exit: 
    // emulator test exit condition
    mov r11, #0x6300
    b end
data:
    .u8 0x3d
    .u8 0xc1
    .u8 0xc7
    .u8 0x56
    .u8 0xc4
    .u8 0xc3
    .u8 0x00
    .u8 0x48
empty:
    .u32fill 30
end:
    b end
.pool        
.end



