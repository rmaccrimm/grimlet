// Primarily making sure every type of shift can be decoded & executed - actual shifter behavior
// is tested fairly thoroughly in src/jit/shift.rs

.begin main
    .arm
    // number of test cases - incremented as we go
    mov r6, #0
    // stack
    ldr sp, =0x03008000
    // flag mask
    ldr r7, =0xf0000000

    b case_1

init:
    add r6, r6, #1
    mov pc, lr

fail:
    ldr r7, =-1
    push {r7}
    b exit

success:
    mov r7, #1
    push {r7}
    mov pc, lr
    
case_1:    
    bl init
    ldr r1, =-4096
    mov r0, r1, asr #11
    ldr r1, =-2
    cmp r0, r1
    bne fail
    bl success

case_2:
    bl init
    ldr r1, =-1
    mov r0, r1, lsr #31
    cmp r0, #1
    bne fail
    bl success

case_3:
    bl init
    ldr r1, =1369
    mov r0, r1, lsl #17
    ldr r1, =179437568
    cmp r0, r1
    bne fail
    bl success

case_4:
    bl init
    ldr r1, =16
    mov r0, r1, ror #23
    ldr r1, =8192
    cmp r0, r1
    bne fail
    bl success

case_5:
    // clear c flag
    eor r0, r0, r0
    msr cpsr_flg, r0    
    bl init
    ldr r1, =2000
    mov r0, r1, rrx
    ldr r1, =1000
    cmp r0, r1
    bne fail
    bl success

case_6:
    bl init
    mov r0, #19
    mov r1, #19
    cmp r0, r1
    bne fail
    bl success

case_7:
    bl init
    mov r1, #0
    mov r2, #0
    mov r0, r1, asr r2
    cmp r0, r1
    bne fail
    bl success

case_8:    
    bl init
    mov r0, #10
    mov r1, #10
    cmp r0, r1
    bne fail
    bl success

case_9:
    bl init
    mov r1, #0
    mov r2, #0
    mov r0, r1, lsr r2
    cmp r0, r1
    bne fail
    bl success

case_10:
    bl init
    mov r0, #29
    mov r1, #29
    cmp r0, r1
    bne fail
    bl success

case_11:
    bl init
    mov r1, #0
    mov r2, #0
    mov r0, r1, lsl r2
    cmp r0, r1
    bne fail
    bl success

case_12:
    bl init
    mov r0, #8
    mov r1, #8
    cmp r0, r1
    bne fail
    bl success

case_13:
    bl init
    mov r1, #0
    mov r2, #0
    mov r0, r1, ror r2
    cmp r0, r1
    bne fail
    bl success

    ldr r3, =case_14
    add r3, r3, #1
    bx r3
.align 4
.thumb
init_t:
    add r6, r6, #1
    mov pc, lr

fail_t:
    ldr r7, =-1
    push {r7}
    ldr r3, =exit
    bx r3

success_t:
    mov r7, #1
    push {r7}
    mov pc, lr

case_14:
    bl init_t
    ldr r0, =-2147483648
    mov r3, r0
    ldr r1, =1
    asr r0, r1 
    ldr r2, =-1073741824   
    cmp r0, r2
    bne fail_t
    bl success_t

case_15:
    bl init_t
    ldr r0, =-2147483648
    ldr r1, =1
    lsr r0, r1
    ldr r1, =1073741824
    cmp r0, r1
    bne fail_t
    bl success_t

case_16:
    bl init_t
    ldr r0, =1
    ldr r1, =8
    lsl r0, r1    
    ldr r1, =256
    cmp r0, r1
    bne fail_t
    bl success_t

case_17:
    bl init_t
    ldr r0, =1
    ldr r1, =1
    ror r0, r1
    ldr r1, =-2147483648 
    cmp r0, r1
    bne fail_t
    bl success_t

case_18:
    bl init_t
    ldr r0, =-2147483648
    asr r0, #17    
    ldr r1, =-16384
    cmp r0, r1
    bne fail_t
    bl success_t

case_19:
    bl init_t
    ldr r0, =-2147483648
    lsr r0, #3
    ldr r1, =268435456
    cmp r0, r1
    bne fail_t
    bl success_t

case_20:
    bl init_t
    ldr r0, =1
    lsl r0, #16
    ldr r1, =65536
    cmp r0, r1
    bne fail_t
    bl success_t
    ldr r3, =exit
    bx r3
.arm
.align 4
exit: 
    // emulator test exit condition
    mov r11, #0x6300
    b end
end:
    b end
    .pool
.end